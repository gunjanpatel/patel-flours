# ─── Required: your Google Sheet ID ─────────────────────────────────────────
# Products are ALWAYS loaded from this sheet (dev and prod).
# Sheet must be shared: File → Share → Anyone with the link → Viewer
# The ID is the long string in your sheet URL between /d/ and /edit
NUXT_PUBLIC_SHEET_ID=YOUR_SHEET_ID_HERE

# ─── Checkout: Cloudflare Worker URL ─────────────────────────────────────────
# Set to MOCK for local development (orders are simulated, nothing is sent).
# Set to your deployed Worker URL for production:
#   e.g. https://organic-shop-worker.yourname.workers.dev
NUXT_PUBLIC_WORKER_URL=MOCK

# ─── GitHub Pages base path (only needed for production builds) ───────────────
NUXT_APP_BASE_URL=/
NUXT_PUBLIC_TURNSTILE_SITE_KEY=